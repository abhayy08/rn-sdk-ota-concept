{
  "name": "SDK_AS_MODULE",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --port=8082",
    "ios": "react-native run-ios --port=8082",
    "lint": "eslint .",
    "start": "react-native start --port=8082",
    "test": "jest",
    "ios:pod:install": "cd ios && pod install && cd ..",
    "yarn:clean": "rm -rf node_modules && yarn cache clean && yarn install",
