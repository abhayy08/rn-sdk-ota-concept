    "mixpanel-react-native": "3.0.8",
    "react": "19.0.0",
    "react-freeze": "1.0.4",
    "react-native": "0.78.0",
    "react-native-code-push": "^9.0.1",
    "react-native-fast-image": "8.6.3",
    "react-native-gesture-handler": "2.24.0",
